# Sanjaya AI Backend — Environment Variables
# Copy this file to .env and fill in your keys.

# LLM Provider preference: "auto" (default), "openai", "groq", "gemini"
LLM_PROVIDER=auto

# Groq (fastest for chat and advisor)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_STORYBOARD=

# OpenAI (best quality for storyboard and advisor)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_STORYBOARD=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_STORYBOARD=

# Feature flags — set to "1" to enable LLM for each flow
SANJAYA_ENABLE_LLM_STORYBOARD=0
SANJAYA_ENABLE_LLM_ADVISOR=0
SANJAYA_ENABLE_LLM_JOB_EXTRACTOR=0
