############################################################
# Sanjaya AI Frontend – Environment Variables (example)
#
# Copy this file to `.env.local` in the same folder:
#   cp .env.local.example .env.local   (macOS/Linux)
#   copy .env.local.example .env.local (Windows PowerShell)
#
# All variables are optional for local development. The
# frontend will default to http://127.0.0.1:8000 for the
# backend API if nothing is set.
############################################################

# Base URL for the FastAPI backend.
# Defaults to http://127.0.0.1:8000 if unset.
NEXT_PUBLIC_API_BASE_URL=

